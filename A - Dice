#include <iostream>
#include <algorithm>
#include <vector>
using namespace std;

int main(void){
  int x;
  cin >> x;
  for(int i=1; i<7; i++){
    for(int j=1; j<7; j++){
      for(int u=1; u<7; u++){
        if(i + j + u == x){
          cout << "Yes" << '\n';
          return 0;
        }
      }
    }
  }
  cout << "No" << '\n';
  return 0;
}
