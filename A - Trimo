#include <iostream>
#include <algorithm>
using namespace std;

int main(void){
  int N, p=0;
  char t;
  cin >> N;
  for(int i=0; i<N; i++){
    cin >> t;
    if(t != 'o'&&p == 0){
      p = 1;
      cout << t;
    }
    else if(p == 1) cout << t;
  }
  if(p == 0) cout << " ";
  cout << '\n';
  return 0;
}
