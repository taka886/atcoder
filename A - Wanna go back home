#include <iostream>
#include <algorithm>
using namespace std;

int main(void){
  int a[4]={0};
  char t;
  while(cin >> t){
    if(t == 'E') a[0] = 1;
    else if(t == 'W') a[1] = 1;
    else if(t == 'S') a[2] = 1;
    else a[3] = 1;
  }
  if(a[0] == a[1]&&a[2] == a[3]) cout << "Yes" <<'\n';
  else cout << "No" << '\n';
  
  return 0;
}
