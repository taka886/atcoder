#include <iostream>
#include <algorithm>
#include <vector>
using namespace std;

int main(void){
  double o = 0;
  int t, id=0;
  vector<double> a(7, 0);
  vector<double> b(7, 0);
  vector<double> c(7, 0);
  vector<double> p(9);
  for(int i=0; i<6; i++){
    cin >> t;
    a[t]++;
  }
  
  for(int i=0; i<6; i++){
    cin >> t;
    b[t]++;
  }
  
  for(int i=0; i<6; i++){
    cin >> t;
    c[t]++;
  }
  
  for(int i=4; i<7; i++){
    p[id] = a[i] / 6;
    id++;
  }
  
  for(int i=4; i<7; i++){
    p[id] = b[i] / 6;
    id++;
  }
  
  for(int i=4; i<7; i++){
    p[id] = c[i] / 6;
    id++;
  }
  for(int i=0; i<3; i++){
      if(i == 0){
        double s = p[i] * p[4] * p[8];
        o += s;
        s = p[i] * p[5] * p[7];
        o += s;
      }
      
      if(i == 1){
        double s = p[i] * p[3] * p[8];
        o += s;
        s = p[i] * p[5] * p[6];
        o += s;
      }
      if(i == 2){
        double s = p[i] * p[3] * p[7];
        o += s;
        s = p[i] * p[4] * p[6];
        o += s;
      }
  }
  cout << o << '\n';
  return 0;
}
