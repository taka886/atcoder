#include <iostream>
#include <algorithm>
using namespace std;

int main(void){
  std::ios::sync_with_stdio(false);
  std::cin.tie(nullptr);
  
  char t = 'x';
  int num = 1, max;
  
  while(t != 'A') cin >> t;
  while(cin >> t){
    num++;
    if(t == 'Z') max = num;
  }
  cout << max << '\n';
  return 0;
}
