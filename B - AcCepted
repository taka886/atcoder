#include <stdio.h>
#include <string.h>

int main(void){
  char s[15];
  int n, cnt_c=0;
  scanf("%s", s);
  n = strlen(s);
  for(int i=0; i<n; i++){
    if(i == 0){
      if(s[i] != 'A'){
        printf("%s\n", "WA");
        return 0;
      }
    }
    else if(2 <= i && i <= n-2){
      if(s[i] == 'C') cnt_c++;
      else if(s[i] < 'a'){
        printf("%s\n", "WA");
        return 0;
      }
    }
    else{
      if(s[i] < 'a'){
        printf("%s\n", "WA");
        return 0;
      }
    }
  }
  if(cnt_c == 1) printf("%s\n", "AC");
  else printf("%s\n", "WA");
  return 0;
}
