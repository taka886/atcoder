#include <stdio.h>

int main(void){
  int N, t[105], t_sum=0, M, p, t_2;
  scanf("%d", &N);
  for(int i=0; i<N; i++){
    scanf("%d", &t[i]);
    t_sum += t[i];
  }
  
  scanf("%d", &M);
  for(int i=0; i<M; i++){
    scanf("%d %d", &p, &t_2);
    printf("%d\n", t_sum - (t[p-1] - t_2));
  }
  return 0;
}
