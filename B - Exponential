#include <iostream>
#include <algorithm>
using namespace std;

int check(int i){
  if(i == 1) return 1;
  else{
    for(int j=2; ;j++){// 1から準にべき乗か判定
      int s = j;
      if(j * j > i) return 0; // 2乗で破綻したところではじく
      while(1){
        s *= j; // jをかけていく
        if(s == i) return 1; // sと一致したらべき乗
        else if(s > i) break; // sを超えてしまったらループを破壊。
      }
    }
  }
}

int main(void){
  
  int N;
  cin >> N;
  for(int i = N; i >= 1; i--){
    if(check(i) == 1){
      cout << i << '\n';
      break;
    }
  }
  return 0;
}
