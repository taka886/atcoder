#include <iostream>
#include <algorithm>
using namespace std;

int main(void){
  int N, max = 1;
  cin >> N;
  if(N == 1){
    cout << 1 << '\n';
    return 0;
  }
  else{
    for(int i=2;i * i <= N ;i++){
      int k = i * i;
      while(k <= N){
        if(max < k) max = k;
        else if(k == N){
          cout << k << '\n';
          return 0;
        }
        k *= i;
      }
    }
  }
  cout << max << '\n';
  return 0;
}
