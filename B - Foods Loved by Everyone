#include <stdio.h>
#include <stdlib.h>

int cmp_int(const void *a, const void *b){
  int x = *(int *)a;
  int y = *(int *)b;
  if(x-y>0) return -1;
  else if(x-y<0) return 1;
  else return 0;
}

int main(void){
  int N, M, a[35]={0}, t, s, sum=0;
  scanf("%d %d", &N, &M);
  for(int i=0; i<N; i++){
    scanf("%d", &t);
    for(int j=0; j<t; j++){
      scanf("%d", &s);
      a[s-1]++;
    }
  }
  qsort(a, M, sizeof(int), cmp_int);
  for(int i=0; i<M; i++){
    if(a[i] == N) sum++;
    else{
      printf("%d", sum);
      return 0;
    }
  }
  printf("%d", sum);
  return 0;
}
