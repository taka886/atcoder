#include <stdio.h>

int search_sqrt(int a){
  if(a == 0) return 0;
  int x=1;
  while(1){
    if(x * x == a) return 1;
    else if(x * x > a) return -1;
    x++;
  }
}

int main(void){
  int N, D, a[15][15], sum, num=0;
  scanf("%d %d", &N, &D);
  for(int i=0; i<N; i++){
    for(int j=0; j<D; j++) scanf("%d", &a[i][j]);
  }
  
  for(int i=0; i<N; i++){
    for(int j=i+1; j<N; j++){
      sum = 0;
      for(int s=0; s<D; s++){
        sum += (a[i][s] - a[j][s]) * (a[i][s] - a[j][s]);
      }
      if(search_sqrt(sum) == 1) num++;
    }
  }
  printf("%d\n", num);
  return 0;
}
