#include <stdio.h>

int main(void){
  int H, W;
  char t;
  scanf("%d %d", &H, &W);
  for(int i=0; i<H+2; i++){
    if(i == 0||i == H+1){
      for(int j=0; j<W+2; j++){
        printf("%c", '#');
      }
      printf("\n");
    }
    else{
      for(int j=0; j<W+2; j++){
        if(j == 0||j == W+1) printf("%c", '#');
        else{
          scanf(" %c", &t);
          printf("%c", t);
        }
      }
      printf("\n");
    }
  }
  return 0;
}
