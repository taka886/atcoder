#include <iostream>
#include <algorithm>
#include <vector>
using namespace std;

int main(void){
  bool is_ok = true;
  int h, w, num=0;
  cin >> h;
  cin >> w;
  vector< vector<char> > a(h, vector<char>(w));
  
  for(int i=0; i<h; i++){
    for(int j=0; j<w; j++){
      cin >> a[i][j];
    }
  }
  
  int h_top, h_bottom=0, w_left, w_right=0;
  
  for(int h_top = 0; h_top < h; h_top++){
    for(int h_bottom = h_top; h_bottom < h; h_bottom++){
      for(int w_left = 0; w_left < w; w_left++){
        for(int w_right = w_left; w_right < w; w_right++){
          for(int i=h_top; i <= h_bottom; i++){
            for(int j=w_left; j <= w_right; j++){
              if(a[i][j] != a[h_top + h_bottom - i][w_left + w_right - j]) is_ok = false;
            }
          }
          if(is_ok == true) num++;
          is_ok = true;
        }
      }
    }
  }
  cout << num << '\n';
  return 0;
}
