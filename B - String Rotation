#include <stdio.h>
#include <string.h>

void rotation_string(char *s, int N){
  char a, b, c = s[N - 1];
  
  for(int i=1; i<N; i+=3){
    if(i == N - 1){
      b = s[i - 1];
      s[i] = b;
      s[i - 1] = c;
    }
    else if(i + 2 == N - 1){
      a = s[i];
      b = s[i - 1];
      s[i] = b;
      s[i - 1] = c;
      c = s[i + 1];
      s[i + 1] = a;
      s[i + 2] = c;
    }
    else{
      a = s[i];
      b = s[i - 1];
      s[i] = b;
      s[i - 1] = c;
      c = s[i + 1];
      s[i + 1] = a;
    }
  }
}

int main(void){
  char s[106], s1[106];
  scanf("%s %s", s, s1);
  int n = strlen(s);
  for(int i=0; i<n; i++){
    if(i == 0){
      if(strcmp(s, s1) == 0){
        printf("%s\n", "Yes");
        return 0;
      }
    }
    else{
      rotation_string(s, n);
      if(strcmp(s, s1) == 0){
        printf("%s\n", "Yes");
        return 0;
      }
    }
  }
  printf("%s\n", "No");
  return 0;
}
