#include <iostream>
#include <algorithm>
using namespace std;

int main(void){
  long long M = 0, t;
  long long N;
  cin >> N;
  for(int i=0; i<N; i++){
    cin >> t;
    if(M > t){
      cout << "No" << '\n';
      return 0;
    }
    if(M == t) M = t;
    else M = t - 1;
  }
  cout << "Yes" << '\n';
  return 0;
}
