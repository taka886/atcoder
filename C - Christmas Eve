#include <iostream>
#include <algorithm>
#include <vector>
using namespace std;

int main(void){
  long n, d, mindiff = 10000000000;
  cin >> n;
  cin >> d;
  vector<long> a(n);
  for(int i=0; i<n; i++){
    cin >> a[i];
  }
  sort(a.begin(), a.end());
  int j = n - 1 - (d - 1);
  for(int i = n - 1; j>=0; i--, j--){
    mindiff = min(a[i] - a[j], mindiff);
  }
  cout << mindiff << '\n';
  return 0;
}
