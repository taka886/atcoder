#include <iostream>
#include <algorithm>
#include <map>
using namespace std;

  map<string, int> a;
  
int main(void){
  int N, maxn = 0;
  string t;
  
  cin >> N;
  for(int i=0; i<N; i++){
    cin >> t;
    a[t]++;
    if(a[t] > maxn) maxn = a[t];
  }
  for (auto const& [string, cut] : a){
    if(cut == maxn) cout << string << '\n';
  }
  return 0;
}
