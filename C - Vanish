#include <iostream>
#include <vector>
#include <algorithm>
using namespace std;

int main(void){
  long long n, k, apper_num=1, all_sum=0, sums_id=0;
  cin >> n;
  cin >> k;
  if(n == 1) cout << 0 << '\n';
  else{
  vector<long long> a(n, 0);
  vector<long long> sums(n, 0);
  for(long long i=0; i<n; i++){
    cin >> a[i];
    all_sum += a[i];
  }
  
  sort(a.rbegin(), a.rend());
  
  for(long long i=1; i<n; i++){
    if(a[i] == a[i - 1]){
      if(i != n - 1) apper_num++;
      else{
        apper_num++;
        sums[sums_id] = apper_num * a[i];
      }
    }
    else{
      sums[sums_id] = apper_num * a[i - 1];
      sums_id++;
      apper_num = 1;
    }
  }
  sort(sums.rbegin(), sums.rend());
  for(int i=0; i<k; i++) all_sum -= sums[i];
  cout << all_sum << '\n';
  }
  return 0;
}
