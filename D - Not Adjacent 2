#include <iostream>
#include <algorithm>
#include <vector>
using namespace std;

int main(void){
  long long n=0;
  int id;
  char t;
  vector<vector<long long>> dp(300005, vector<long long>(3, 0));
  cin >> t;
  dp[0][t - 'a'] = 1;
  for(long long i=1; cin >> t; i++){
    if(t == 'a'){
      dp[i][0] = (dp[i - 1][0] + dp[i - 1][1] + dp[i - 1][2] + 1) % 998244353;
      dp[i][1] = dp[i - 1][1];
      dp[i][2] = dp[i - 1][2];
    }
    else if(t == 'b'){
      dp[i][0] = dp[i - 1][0];
      dp[i][1] = (dp[i - 1][1] + dp[i - 1][0] + dp[i - 1][2] + 1) % 998244353;
      dp[i][2] = dp[i - 1][2];
    }
    else{
      dp[i][0] = dp[i - 1][0];
      dp[i][1] = dp[i - 1][1];
      dp[i][2] = (dp[i - 1][2] + dp[i - 1][0] + dp[i - 1][1] + 1) % 998244353;
    }
    n++;
  }
  cout << (dp[n][0] + dp[n][1] + dp[n][2]) % 998244353 << '\n';
  return 0;
}
